    <link rel="manifest" href="manifest.json">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&amp;family=Playfair+Display:wght@700&amp;display=swap');
        
        body { font-family: 'Inter', system_ui, sans-serif; }
        .heading-serif { font-family: 'Playfair Display', Georgia, serif; }

        .glass {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(226, 232, 240, 0.6);
        }
        .dark .glass {
            background: rgba(15, 23, 42, 0.92);
            border: 1px solid rgba(51, 65, 85, 0.6);
        }

        .premium-shadow { box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25), 0 10px 10px -6px rgb(0 0 0 / 0.15); }
        
        .section-header { position: relative; display: inline-block; }
        .section-header:after {
            content: ''; position: absolute; bottom: -6px; left: 0; width: 55%; height: 3px;
            background: linear-gradient(to right, #D4AF37, transparent); border-radius: 9999px;
        }

        .nav-active { background: linear-gradient(90deg, #1E3A8A, #3B82F6); color: white; box-shadow: 0 10px 15px -3px rgb(30 58 138 / 0.35); }

        .modern-table { border-radius: 16px; overflow: hidden; box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.06); }
        
        .premium-btn {
            transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
            position: relative; overflow: hidden;
        }
        .premium-btn:after {
            content: ''; position: absolute; top: -50%; left: -100%; width: 50%; height: 200%;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.35), transparent);
            transition: 0.6s;
        }
        .premium-btn:hover:after { left: 250%; }

        .form-input {
            transition: all 0.2s ease;
        }
        .form-input:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.15);
            border-color: #1E3A8A;
        }

        .invoice-line {
            transition: background-color 0.15s ease;
        }
        .invoice-line:hover { background-color: #F8FAFC; }
        .dark .invoice-line:hover { background-color: #1E293B; }

        .screen { display: none; }
        .screen.active { display: block; }

        .metric-value { font-variant-numeric: tabular-nums; }
        
        .gold-text { color: #D4AF37; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-100">
    
