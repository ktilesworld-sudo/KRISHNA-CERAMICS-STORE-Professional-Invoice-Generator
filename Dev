                                    <th class="px-6 py-3 text-left w-2/5">Product</th>
                                    <th class="px-4 py-3 text-center">HSN</th>
                                    <th class="px-4 py-3 text-center">Qty (Boxes)</th>
                                    <th class="px-4 py-3 text-right">Rate</th>
                                    <th class="px-4 py-3 text-right">Taxable</th>
                                    <th class="px-4 py-3 text-right">CGST</th>
                                    <th class="px-4 py-3 text-right">SGST/IGST</th>
                                    <th class="px-4 py-3 text-right">Total</th>
                                    <th class="px-3 py-3 w-8"></th>
                                </tr>
                            </thead>
                            <tbody id="invoiceItemsBody" class="divide-y divide-slate-100 dark:divide-slate-700 text-sm">
                                <!-- Rows added dynamically by app.js -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Right Column: Totals + Transport + Actions -->
            <div class="xl:col-span-4 space-y-6">
                
                <!-- Totals Card -->
                <div class="glass rounded-3xl p-8 border border-slate-200 dark:border-slate-700 sticky top-24">
                    <h3 class="font-semibold text-xl mb-6">Invoice Summary</h3>
                    
                    <div class="space-y-4 text-sm">
                        <div class="flex justify-between"><span class="text-slate-600 dark:text-slate-300">Subtotal (Taxable)</span> <span id="subtotalAmount" class="font-semibold tabular-nums">₹0.00</span></div>
                        <div class="flex justify-between"><span class="text-slate-600 dark:text-slate-300">Total CGST</span> <span id="gstTotalAmount" class="font-semibold tabular-nums">₹0.00</span></div>
                        <div class="flex justify-between"><span class="text-slate-600 dark:text-slate-300">Total SGST / IGST</span> <span id="igstTotalAmount" class="font-semibold tabular-nums">₹0.00</span></div>
                        
                        <div class="h-px bg-slate-200 dark:bg-slate-700 my-2"></div>
                        
                        <div class="flex justify-between items-baseline text-xl">
                            <span class="font-semibold">Grand Total</span> 
                            <span id="grandTotalAmount" class="font-bold tabular-nums text-3xl text-[#1E3A8A]">₹0.00</span>
                        </div>
                        
                        <div class="pt-3 text-xs text-slate-500">
                            Amount in Words: <span id="amountInWords" class="font-medium text-slate-700 dark:text-slate-200"></span>
                        </div>
                    </div>
                </div>

                <!-- Transport -->
                <div class="glass rounded-3xl p-7 border border-slate-200 dark:border-slate-700">
                    <h3 class="font-semibold mb-4">Transport Details</h3>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="text-xs font-medium text-slate-500">Transport</label>
                            <input id="transportSelect" type="text" placeholder="Search transporter..." 
                                   class="form-input mt-1 w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-2xl px-4 py-2.5 text-sm">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-xs font-medium text-slate-500">LR Number</label>
                                <input id="lrNumber" type="text" class="form-input mt-1 w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-2xl px-4 py-2 text-sm">
                            </div>
                            <div>
                                <label class="text-xs font-medium text-slate-500">Vehicle No</label>
                                <input id="vehicleNumber" type="text" class="form-input mt-1 w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-2xl px-4 py-2 text-sm">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                <div class="glass rounded-3xl p-7 border border-slate-200 dark:border-slate-700">
                    <label class="text-xs font-medium text-slate-500">Notes / Narration</label>
                    <textarea id="invoiceNotes" rows="3" placeholder="Any special instructions..." 
                              class="form-input mt-2 w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-2xl px-4 py-3 text-sm resize-y"></textarea>
                </div>

                <!-- Action Buttons -->
                <div class="space-y-3 pt-2">
                    <button id="generatePDFBtn"
                            class="w-full py-4 rounded-3xl bg-gradient-to-r from-[#1E3A8A] to-[#3B82F6] text-white font-semibold text-lg flex items-center justify-center gap-x-3 premium-btn active:scale-[0.985]">
                        <span>Generate &amp; Download Premium PDF</span>
                    </button>
                    
                    <div class="grid grid-cols-2 gap-3">
                        <button id="clearInvoiceBtn"
                                class="py-3.5 rounded-3xl border border-slate-300 dark:border-slate-600 font-semibold text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition">Clear Form</button>
                        <button onclick="showScreen('homeScreen')"
                                class="py-3.5 rounded-3xl border border-slate-300 dark:border-slate-600 font-semibold text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden Utility Inputs (for app.js) -->
    <input type="file" id="excelFile" accept=".xlsx,.xls" hidden>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed bottom-6 right-6 z-[200] space-y-3"></div>

    <!-- Core Script (Minimal for screen switching + theme. Full logic in app.js) -->
    <script>
        function initializeTailwind() {
            // Tailwind already loaded via CDN
        }

        function toggleTheme() {
            const html = document.documentElement;
            html.classList.toggle('dark');
            localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
            updateThemeIcon();
        }

        function updateThemeIcon() {
            const icon = document.getElementById('theme-icon');
            if (!icon) return;
            icon.innerHTML = document.documentElement.classList.contains('dark') 
                ? `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />`
                : `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />`;
        }

        function initTheme() {
            if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            }
            updateThemeIcon();
        }

        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            let bg = type === 'error' ? 'bg-red-600' : type === 'info' ? 'bg-blue-600' : 'bg-emerald-600';
            
            toast.className = `px-6 py-4 rounded-3xl shadow-2xl text-white flex items-center gap-x-3 max-w-sm ${bg}`;
            toast.innerHTML = `
                <div class="flex-1 text-sm font-medium">${message}</div>
                <button onclick="this.parentElement.remove()" class="text-xl leading-none opacity-70 hover:opacity-100">×</button>
            `;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 4200);
        }

        function showScreen(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId).classList.add('active');
            
            // Update nav active state
            document.getElementById('nav-home').classList.toggle('nav-active', screenId === 'homeScreen');
            document.getElementById('nav-invoice').classList.toggle('nav-active', screenId === 'invoiceScreen');
        }

        function performQuickBackup() {
            showToast('Creating local backup... (storage.js will handle full export)', 'info');
        }

        function initializeApp() {
            initializeTailwind();
            initTheme();
            
            // Show dashboard by default
            document.getElementById('homeScreen').classList.add('active');
            
            // Keyboard shortcut hint
            document.addEventListener('keydown', function(e) {
                if (e.ctrlKey && e.key.toLowerCase() === 'n') {
                    e.preventDefault();
                    showScreen('invoiceScreen');
                }
            });
            
            // Demo: Show one toast on first load
            setTimeout(() => {
                if (!localStorage.getItem('seenWelcome')) {
                    showToast('Welcome! Press Ctrl + N to create new invoice quickly.', 'info');
                    localStorage.setItem('seenWelcome', 'true');
                }
            }, 2800);
            
            console.log('%c[Krishna Invoice] index.html initialized with full DOM structure for app.js', 'color:#64748b');
        }

        window.onload = initializeApp;
    </script>
</body>
</html>
